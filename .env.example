# Mify 知识库检索 API
MIFY_API_KEY=dataset-your-api-key-here
MIFY_DATASET_IDS=your-dataset-id-1,your-dataset-id-2

# 检索参数
MIFY_TOP_K=5

# RAG-Fusion 参数
MIFY_RRF_K=60
MIFY_NUM_VARIANTS=5
MIFY_RETRIEVE_WORKERS=3

# LLM 客户端（通过 Mify 代理调用）
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://service.mify.mioffice.cn/v1
LLM_MODEL=mimo-v2.5-pro

# MCP Transport: stdio | sse
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8003
